# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/ce_website
# Production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ce_website

# ─── CORS ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Email Notifications (optional) ──────────────
# Fill these in to receive email alerts on new contact submissions
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=christopher@example.com

# ─── Admin Panel ──────────────────────────────────
# Change these before deploying to production!
JWT_SECRET=change_this_to_a_long_random_string_in_production
ADMIN_PASSWORD=changeme123
